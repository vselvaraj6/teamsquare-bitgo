BITGO_ACCESS_TOKEN=your_bitgo_testnet_access_token
BITGO_WALLET_ID=your_wallet_id
BITGO_COIN=tsol
OPENAI_API_KEY=your_openai_api_key
CHAINABUSE_API_KEY=         # get free key at chainabuse.com (Settings > API Key)

# Required for execute_transaction — sendcoins is a BitGo Express endpoint.
# Run Express locally: npx @bitgo/express@latest --env test --bind localhost --port 3080
# Then set this to your Express URL (default below):
BITGO_EXPRESS_URL=http://localhost:3080
